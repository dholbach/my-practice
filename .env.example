# Django
# Generate with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=GENERATE_A_KEY_AND_PUT_IT_HERE
# Fernet key for encrypting clinical fields (Art. 9 DSGVO data).
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# REQUIRED for P-009 clinical models. Keep this key safe — loss means clinical data is unrecoverable.
FERNET_KEY=GENERATE_A_KEY_AND_PUT_IT_HERE
# Dev setup only — do not set to False in docker-compose.yml; use docker-compose.prod.yml for production.
DJANGO_DEBUG=True
# Comma-separated list of allowed hosts, or "*" for dev only
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# PostgreSQL database
POSTGRES_DB=my_practice
POSTGRES_USER=my_practice
POSTGRES_PASSWORD=CHANGE_THIS_TO_A_STRONG_PASSWORD
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Email Configuration (Proton Bridge)
# Set to "true" to enable SMTP via Proton Bridge
USE_PROTON_BRIDGE=false
EMAIL_HOST=127.0.0.1
EMAIL_PORT=1025
EMAIL_HOST_USER=your-email@proton.me
EMAIL_HOST_PASSWORD=your-proton-bridge-password
DEFAULT_FROM_EMAIL=your-email@proton.me

# Google Calendar API (Optional - for calendar import proof of concept)
# Create OAuth2 credentials at: https://console.cloud.google.com/
# Authorized redirect URI: http://localhost:8000/calendar/oauth2callback/
# Add yourself as test user in OAuth consent screen
GOOGLE_CALENDAR_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CALENDAR_CLIENT_SECRET=GOCSPX-your-client-secret

# External data directory — MUST be outside the git repository.
# Contains: backups/ and media/ subdirectories.
# Default (if unset): ../my-practice-data  (sibling of the repo clone)
# Recommended: set an absolute path specific to this machine, e.g.
#   MY_PRACTICE_DATA_DIR=/home/youruser/data/my-practice
MY_PRACTICE_DATA_DIR=/path/to/your/my-practice-data

# Update check — the app checks GitHub releases once per day and shows a banner
# when a newer version is available. Set to "true" to disable.
UPDATE_CHECK_DISABLED=false
