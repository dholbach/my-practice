# Sensible Daten
.env

# Project-level memory notes (instance-specific, not for public repo)
memory/

# Personal operational docs — use gitignored copies or MY_PRACTICE_DATA_DIR for filled-in versions
docs/operations/DPIA.md
docs/operations/REINSTALL_CHECKLIST.md
backups/

# Media files MUST live outside the repo (see PAYMENTS_DATA_DIR in .env).
# This entry is a fallback safety net in case someone accidentally points
# MEDIA_ROOT / a volume mount back inside the repo checkout.
media/
app/media/

# Generierte Rechnungen (enthält Klientendaten)
invoices/
*.pdf

# Docker Volumes
postgres_data/

# Logs
*.log

# Temporäre Test-Ausgaben
test_results.txt

# Backup-Dateien
backup/
*.backup
*.sql.gz

# OS
.DS_Store
Thumbs.db
*/__pycache__/

# Test artifacts
.coverage
app/.coverage
htmlcov/

# Tailwind compiled output (generated by npm run build:css)
app/static/css/tailwind.out.css
app/node_modules/

# i18n compiled message files (generated by ./dev.py compilemessages)
app/locale/**/*.mo
